{
  "name": "Split Column",
  "version": "2.0.0",
  "author": "r0astr",
  "description": "Three-column layout: headers left, editors center, controls right, with global toolbar",
  "layoutType": "tree",
  "cssVariables": {
    "--color-primary": "#b6f0fe",
    "--primary-color": "#b6f0fe"
  },
  "css": {},
  "layout": {
    "regions": {
      "toolbar": { "selector": "#region-toolbar" },
      "left":    { "selector": "#region-left" },
      "center":  { "selector": "#region-center" },
      "right":   { "selector": "#region-right" }
    },
    "panelParts": {
      "header":   { "region": "left" },
      "editor":   { "region": "center" },
      "controls": { "region": "right" }
    },
    "headerClickBehavior": "toggle",
    "resizableRegions": true
  },
  "templates": {
    "panel": "panel.html",
    "panel-header": "panel-header.html",
    "panel-editor": "panel-editor.html",
    "panel-controls": "panel-controls.html",
    "page": "page-layout.html",
    "slider": "slider.html",
    "sliderCollapsed": "slider-collapsed.html"
  },
  "hoverTargets": []
}
